<Window x:Class="EditorDbf.App.Views.ExportView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:infra="clr-namespace:EditorDbf.App.Infrastructure"
        xmlns:vm="clr-namespace:EditorDbf.App.ViewModels"
        mc:Ignorable="d"
        Title="Exportar Datos" 
        Height="420" Width="520"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"
        FontSize="13">

    <Window.Resources>
        <infra:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Ruta -->
            <RowDefinition Height="Auto"/> <!-- Ámbito -->
            <RowDefinition Height="Auto"/> <!-- Formato -->
            <RowDefinition Height="Auto"/> <!-- Botones -->
        </Grid.RowDefinitions>

        <!-- Destino -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Carpeta y nombre de archivo de destino:" 
                       Margin="0,0,0,8" 
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8,5"
                         VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" 
                        Content="..." 
                        Command="{Binding BrowseCommand}"
                        Width="40" Margin="8,0,0,0"
                        Padding="0,0,0,2"/>
            </Grid>
        </StackPanel>

        <!-- Ámbito -->
        <GroupBox Grid.Row="1" Header="ÁMBITO DE EXPORTACIÓN">
            <StackPanel>
                <RadioButton Content="Todos los registros (aplicando filtros actuales)" 
                             IsChecked="{Binding Scope, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:ExportScope.All}}"
                             Margin="0,5"/>
                <RadioButton Content="Solo registros seleccionados" 
                             IsEnabled="{Binding CanExportSelected}"
                             IsChecked="{Binding Scope, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:ExportScope.Selected}}"
                             Margin="0,5"/>
            </StackPanel>
        </GroupBox>

        <!-- Formato -->
        <GroupBox Grid.Row="2" Header="FORMATO DE ARCHIVO">
            <ComboBox ItemsSource="{Binding AvailableFormats}"
                      SelectedItem="{Binding SelectedFormat}"
                      Padding="8,5"
                      VerticalContentAlignment="Center"/>
        </GroupBox>

        <!-- Botones -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,10">
            <Button Content="Cancelar" 
                    IsCancel="True"
                    Width="100" Margin="0,0,10,0"/>
            <Button Content="Exportar" 
                    IsDefault="True"
                    Click="Export_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100"/>
        </StackPanel>
    </Grid>
</Window>
