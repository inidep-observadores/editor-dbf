<Application x:Class="EditorDbf.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:EditorDbf.App.Infrastructure">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Tema activo: LightTheme o DarkTheme (se intercambia en runtime) -->
                <ResourceDictionary Source="Themes/LightTheme.xaml"/>
                <!-- Estilos de controles (usan DynamicResource para responder al tema) -->
                <ResourceDictionary Source="Themes/ControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Converters globales -->
            <infra:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <infra:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <infra:CellModifiedConverter x:Key="CellModifiedConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
