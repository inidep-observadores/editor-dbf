<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackgroundBrush"              Color="#1C1C1C"/>
    <SolidColorBrush x:Key="LayerBackgroundBrush"            Color="#272727"/>
    <SolidColorBrush x:Key="SubLayerBackgroundBrush"         Color="#202020"/>
    <SolidColorBrush x:Key="ToolbarBackgroundBrush"          Color="#1E1E1E"/>
    <SolidColorBrush x:Key="StatusBarBackgroundBrush"        Color="#171717"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="PanelBorderBrush"                Color="#393939"/>
    <SolidColorBrush x:Key="DividerBrush"                    Color="#2E2E2E"/>
    <SolidColorBrush x:Key="GridBorderBrush"                 Color="#333333"/>
    <SolidColorBrush x:Key="ButtonBorderBrush"               Color="#404040"/>
    <SolidColorBrush x:Key="ButtonHoverBorderBrush"          Color="#4A4A4A"/>
    <SolidColorBrush x:Key="ButtonPressedBorderBrush"        Color="#545454"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush"                Color="#F2F2F2"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"              Color="#9E9E9E"/>
    <SolidColorBrush x:Key="CaptionTextBrush"                Color="#6A6A6A"/>
    <SolidColorBrush x:Key="DisabledTextBrush"               Color="#4A4A4A"/>
    <SolidColorBrush x:Key="TextOnAccentBrush"               Color="#000000"/>

    <!-- Accent (Windows light blue for dark theme) -->
    <SolidColorBrush x:Key="AccentBrush"                     Color="#60CDFF"/>
    <SolidColorBrush x:Key="AccentHoverBrush"                Color="#78D6FF"/>
    <SolidColorBrush x:Key="AccentPressedBrush"              Color="#48C0F5"/>
    <SolidColorBrush x:Key="AccentSubtleBrush"               Color="#1A3A52"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush"           Color="#2D2D2D"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush"      Color="#373737"/>
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush"    Color="#424242"/>

    <!-- Lists -->
    <SolidColorBrush x:Key="ListItemHoverBackgroundBrush"    Color="#303030"/>
    <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="#1A3A58"/>
    <SolidColorBrush x:Key="ListItemSelectedTextBrush"       Color="#F2F2F2"/>
    <SolidColorBrush x:Key="ListItemSelectedAccentBrush"     Color="#60CDFF"/>

    <!-- Data grid -->
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush"       Color="#222222"/>
    <SolidColorBrush x:Key="GridAltRowBackgroundBrush"       Color="#252525"/>
    <SolidColorBrush x:Key="GridRowHoverBackgroundBrush"     Color="#1C3040"/>
    <SolidColorBrush x:Key="GridSelectedRowBrush"            Color="#1A3A58"/>

    <!-- Tabs -->
    <SolidColorBrush x:Key="TabStripBackgroundBrush"         Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TabItemHoverBackgroundBrush"     Color="#2E2E2E"/>
    <SolidColorBrush x:Key="TabItemSelectedBackgroundBrush"  Color="#272727"/>
    <SolidColorBrush x:Key="TabItemSelectedBorderBrush"      Color="#60CDFF"/>

    <!-- State -->
    <SolidColorBrush x:Key="DangerBrush"                     Color="#FF8C8C"/>
    <SolidColorBrush x:Key="DangerHoverBrush"                Color="#FF9E9E"/>
    <SolidColorBrush x:Key="DangerPressedBrush"              Color="#F07070"/>
    <SolidColorBrush x:Key="DangerForegroundBrush"           Color="#1C1C1C"/>
    <SolidColorBrush x:Key="SuccessBrush"                    Color="#6CCB6C"/>
    <SolidColorBrush x:Key="SuccessForegroundBrush"          Color="#1C1C1C"/>
    <SolidColorBrush x:Key="WarnBrush"                       Color="#FFB84D"/>

    <!-- Shadow is invisible in dark theme -->
    <Color x:Key="ShadowColor">#00000000</Color>
</ResourceDictionary>
