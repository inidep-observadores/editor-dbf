<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackgroundBrush"              Color="#F0F0F0"/>
    <SolidColorBrush x:Key="LayerBackgroundBrush"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SubLayerBackgroundBrush"         Color="#F6F6F6"/>
    <SolidColorBrush x:Key="ToolbarBackgroundBrush"          Color="#E8E8E8"/>
    <SolidColorBrush x:Key="StatusBarBackgroundBrush"        Color="#DEDEDE"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="PanelBorderBrush"                Color="#DCDCDC"/>
    <SolidColorBrush x:Key="DividerBrush"                    Color="#EBEBEB"/>
    <SolidColorBrush x:Key="GridBorderBrush"                 Color="#E8E8E8"/>
    <SolidColorBrush x:Key="ButtonBorderBrush"               Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ButtonHoverBorderBrush"          Color="#BCBCBC"/>
    <SolidColorBrush x:Key="ButtonPressedBorderBrush"        Color="#ACACAC"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush"                Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"              Color="#5C5C5C"/>
    <SolidColorBrush x:Key="CaptionTextBrush"                Color="#999999"/>
    <SolidColorBrush x:Key="DisabledTextBrush"               Color="#C0C0C0"/>
    <SolidColorBrush x:Key="TextOnAccentBrush"               Color="#FFFFFF"/>

    <!-- Accent (Windows blue) -->
    <SolidColorBrush x:Key="AccentBrush"                     Color="#0067C0"/>
    <SolidColorBrush x:Key="AccentHoverBrush"                Color="#1875C9"/>
    <SolidColorBrush x:Key="AccentPressedBrush"              Color="#0054A0"/>
    <SolidColorBrush x:Key="AccentSubtleBrush"               Color="#D0E8F8"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush"           Color="#FCFCFC"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush"      Color="#EFEFEF"/>
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush"    Color="#E3E3E3"/>

    <!-- Lists -->
    <SolidColorBrush x:Key="ListItemHoverBackgroundBrush"    Color="#EEEEEE"/>
    <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="#C8E0F5"/>
    <SolidColorBrush x:Key="ListItemSelectedTextBrush"       Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ListItemSelectedAccentBrush"     Color="#0067C0"/>

    <!-- Data grid -->
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush"       Color="#EEEEEE"/>
    <SolidColorBrush x:Key="GridAltRowBackgroundBrush"       Color="#F8F8F8"/>
    <SolidColorBrush x:Key="GridRowHoverBackgroundBrush"     Color="#E6F2FB"/>
    <SolidColorBrush x:Key="GridSelectedRowBrush"            Color="#C8E0F5"/>

    <!-- Tabs -->
    <SolidColorBrush x:Key="TabStripBackgroundBrush"         Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TabItemHoverBackgroundBrush"     Color="#EDEDED"/>
    <SolidColorBrush x:Key="TabItemSelectedBackgroundBrush"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TabItemSelectedBorderBrush"      Color="#0067C0"/>

    <!-- State -->
    <SolidColorBrush x:Key="DangerBrush"                     Color="#C42B1C"/>
    <SolidColorBrush x:Key="DangerHoverBackgroundBrush"      Color="#FDE7E9"/>
    <SolidColorBrush x:Key="DangerHoverBrush"                Color="#D44030"/>
    <SolidColorBrush x:Key="DangerPressedBrush"              Color="#A82315"/>
    <SolidColorBrush x:Key="DangerForegroundBrush"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DangerTextBrush"                 Color="#C42B1C"/>
    <SolidColorBrush x:Key="SuccessBrush"                    Color="#107C10"/>
    <SolidColorBrush x:Key="SuccessForegroundBrush"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WarnBrush"                       Color="#9D5D00"/>

    <!-- Shadow for cards -->
    <Color x:Key="ShadowColor">#30000000</Color>
</ResourceDictionary>
