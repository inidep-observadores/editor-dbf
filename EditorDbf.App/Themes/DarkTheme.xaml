<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackgroundBrush"              Color="#1C1C1C"/>
    <SolidColorBrush x:Key="LayerBackgroundBrush"            Color="#2D2D2D"/>
    <SolidColorBrush x:Key="SubLayerBackgroundBrush"         Color="#363636"/>
    <SolidColorBrush x:Key="ToolbarBackgroundBrush"          Color="#252525"/>
    <SolidColorBrush x:Key="StatusBarBackgroundBrush"        Color="#1A1A1A"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="PanelBorderBrush"                Color="#404040"/>
    <SolidColorBrush x:Key="DividerBrush"                    Color="#454545"/>
    <SolidColorBrush x:Key="GridBorderBrush"                 Color="#3D3D3D"/>
    <SolidColorBrush x:Key="ButtonBorderBrush"               Color="#505050"/>
    <SolidColorBrush x:Key="ButtonHoverBorderBrush"          Color="#606060"/>
    <SolidColorBrush x:Key="ButtonPressedBorderBrush"        Color="#707070"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush"                Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"              Color="#A0A0A0"/>
    <SolidColorBrush x:Key="CaptionTextBrush"                Color="#707070"/>
    <SolidColorBrush x:Key="DisabledTextBrush"               Color="#505050"/>
    <SolidColorBrush x:Key="TextOnAccentBrush"               Color="#FFFFFF"/>

    <!-- Accent (Windows blue) -->
    <SolidColorBrush x:Key="AccentBrush"                     Color="#60CDFF"/>
    <SolidColorBrush x:Key="AccentHoverBrush"                Color="#76D5FF"/>
    <SolidColorBrush x:Key="AccentPressedBrush"              Color="#4BAED9"/>
    <SolidColorBrush x:Key="AccentSubtleBrush"               Color="#1A3E4F"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush"           Color="#3D3D3D"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush"      Color="#454545"/>
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush"    Color="#333333"/>

    <!-- Lists -->
    <SolidColorBrush x:Key="ListItemHoverBackgroundBrush"    Color="#404040"/>
    <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="#1A3E4F"/>
    <SolidColorBrush x:Key="ListItemSelectedTextBrush"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ListItemSelectedAccentBrush"     Color="#60CDFF"/>

    <!-- Data grid -->
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush"       Color="#333333"/>
    <SolidColorBrush x:Key="GridAltRowBackgroundBrush"       Color="#313131"/>
    <SolidColorBrush x:Key="GridRowHoverBackgroundBrush"     Color="#3D3D3D"/>
    <SolidColorBrush x:Key="GridSelectedRowBrush"            Color="#1A3E4F"/>

    <!-- Tabs -->
    <SolidColorBrush x:Key="TabStripBackgroundBrush"         Color="#252525"/>
    <SolidColorBrush x:Key="TabItemHoverBackgroundBrush"     Color="#363636"/>
    <SolidColorBrush x:Key="TabItemSelectedBackgroundBrush"  Color="#2D2D2D"/>
    <SolidColorBrush x:Key="TabItemSelectedBorderBrush"      Color="#60CDFF"/>

    <!-- State -->
    <SolidColorBrush x:Key="DangerBrush"                     Color="#FF8C8C"/>
    <SolidColorBrush x:Key="DangerHoverBackgroundBrush"      Color="#3D2020"/>
    <SolidColorBrush x:Key="DangerHoverBrush"                Color="#FF9999"/>
    <SolidColorBrush x:Key="DangerPressedBrush"              Color="#FF7070"/>
    <SolidColorBrush x:Key="DangerForegroundBrush"           Color="#1C1C1C"/>
    <SolidColorBrush x:Key="DangerTextBrush"                 Color="#FF8C8C"/>
    <SolidColorBrush x:Key="SuccessBrush"                    Color="#6CCB5F"/>
    <SolidColorBrush x:Key="SuccessForegroundBrush"          Color="#1C1C1C"/>
    <SolidColorBrush x:Key="WarnBrush"                       Color="#FFB900"/>

    <!-- Shadow for cards -->
    <Color x:Key="ShadowColor">#FF000000</Color>
    <SolidColorBrush x:Key="OverlayBrush"                    Color="#80000000"/>
</ResourceDictionary>
