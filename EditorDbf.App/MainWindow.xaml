<Window x:Class="EditorDbf.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:infra="clr-namespace:EditorDbf.App.Infrastructure"
        xmlns:vm="clr-namespace:EditorDbf.App.ViewModels"
        mc:Ignorable="d"
        Title="Editor DBF"
        Icon="assets/app_icon.png"
        WindowState="Maximized"
        Height="900"
        Width="1500"
        MinHeight="720"
        MinWidth="1200"
        FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"
        FontSize="13"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">

    <Window.Resources>
        <infra:FilterParamOperatorConverter x:Key="FilterParamOperatorConverter"/>
        <infra:FilterDisplayConverter x:Key="FilterDisplayConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Contenido principal -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  TOOLBAR                                                         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="8,4">

                <!-- Botón toggle de tema (derecha) -->
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource IconButtonStyle}"
                        Command="{Binding ToggleThemeCommand}"
                        Margin="0,0,2,0"
                        Width="32" Height="32" Padding="0">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock x:Name="ThemeTooltipText" Text="Cambiar tema"/>
                        </ToolTip>
                    </Button.ToolTip>
                    <TextBlock x:Name="ThemeIcon"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15"
                               Text="&#xE708;"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>

                <!-- Grupo: Tabla y registros -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Conexiones -->
                    <Button Command="{Binding AddConnectionCommand}"
                            ToolTip="Nueva conexión"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Nueva conexión" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RemoveConnectionCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            ToolTip="Eliminar conexión seleccionada"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Eliminar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator/>

                    <!-- Archivos -->
                    <Button Command="{Binding RefreshFilesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Actualizar lista de archivos"
                            Width="32" Height="32" Padding="0"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <Button Command="{Binding OpenTableCommand}"
                            ToolTip="Abrir archivo DBF seleccionado"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Abrir DBF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CloseSelectedTabCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Cerrar pestaña activa"
                            Width="32" Height="32" Padding="0"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <Button Command="{Binding OpenSqlConsoleCommand}"
                            ToolTip="Abrir consola SQL"
                            Margin="4,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Consola SQL" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator/>

                    <!-- Registros -->
                    <Button Command="{Binding AddRecordCommand}"
                            ToolTip="Agregar nuevo registro"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Agregar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding DeleteSelectedRecordCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            ToolTip="Borrar registros seleccionados"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xECC9;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Borrar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ReloadTableCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Recargar tabla desde disco (descarta cambios)"
                            Width="32" Height="32" Padding="0"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <Button Command="{Binding SaveTableCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Guardar cambios en el archivo DBF"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Guardar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator/>

                    <Button Command="{Binding ImportFromTableCommand}"
                            ToolTip="Importar registros desde otro DBF (APPEND FROM)"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Importar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  CONTENIDO PRINCIPAL (3 columnas con splitters)                 -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="140"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="380" MinWidth="360"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────────────────── -->
            <!--  PANEL IZQUIERDO: Conexiones                         -->
            <!-- ─────────────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource LayerBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="6"
                                      Color="{DynamicResource ShadowColor}"
                                      Opacity="1" Direction="270"/>
                </Border.Effect>
                <DockPanel Margin="0,0,0,0">
                    <!-- Header -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource SubLayerBackgroundBrush}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="8,8,0,0"
                            Padding="12,10">
                        <TextBlock Text="CONEXIONES"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource CaptionTextBrush}"/>
                    </Border>
                    <!-- Lista -->
                    <ListBox ItemsSource="{Binding Connections}"
                             SelectedItem="{Binding SelectedConnection, Mode=TwoWay}"
                             DisplayMemberPath="DisplayName"
                             BorderThickness="0"
                             Margin="4,4,4,4"/>
                </DockPanel>
            </Border>

            <!-- Splitter izquierdo -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Cursor="SizeWE"
                          Margin="0"/>

            <!-- ─────────────────────────────────────────────────── -->
            <!--  PANEL CENTRAL: Dinámico según contexto              -->
            <!-- ─────────────────────────────────────────────────── -->
            <ContentControl Grid.Column="2" Content="{Binding SelectedOpenTable}">
                <ContentControl.Resources>
                    <!-- Template para el Explorador de Archivos (Modo Tabla) -->
                    <ControlTemplate x:Key="FileExplorerTemplate">
                        <Border Background="{DynamicResource LayerBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="6"
                                                  Color="{DynamicResource ShadowColor}"
                                                  Opacity="1" Direction="270"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="2*" MinHeight="80"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="3*" MinHeight="80"/>
                                </Grid.RowDefinitions>

                                <!-- Header Archivos -->
                                <Border Grid.Row="0"
                                        Background="{DynamicResource SubLayerBackgroundBrush}"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="8,8,0,0"
                                        Padding="12,10">
                                    <DockPanel>
                                        <TextBlock Text="ARCHIVOS DBF"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource CaptionTextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.RefreshFilesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                ToolTip="Actualizar lista de archivos"
                                                Width="26" Height="26">
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                    </DockPanel>
                                </Border>

                                <ListBox Grid.Row="1"
                                         x:Name="DbfFilesList"
                                         MouseDoubleClick="DbfFilesList_OnMouseDoubleClick"
                                         ItemsSource="{Binding DataContext.DbfFiles, RelativeSource={RelativeSource AncestorType=Window}}"
                                         SelectedItem="{Binding DataContext.SelectedDbfFile, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                         BorderThickness="0"
                                         Margin="4,4,4,0">
                                    <ListBox.InputBindings>
                                        <KeyBinding Key="Delete" Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </ListBox.InputBindings>
                                    <ListBox.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Refrescar" 
                                                      Command="{Binding DataContext.RefreshFilesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Icon="{infra:Icon Text=&#xE72C;}"/>
                                            <Separator/>
                                            <MenuItem Header="Eliminar archivo" 
                                                      Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Icon="{infra:Icon Text=&#xE74D;}"/>
                                            <Separator/>
                                            <MenuItem Header="Mostrar en el explorador" 
                                                      Command="{Binding DataContext.ShowInExplorerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Icon="{infra:Icon Text=&#xED25;}"/>
                                        </ContextMenu>
                                    </ListBox.ContextMenu>
                                </ListBox>

                                <GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Cursor="SizeNS" ResizeBehavior="PreviousAndNext">
                                    <GridSplitter.Template>
                                        <ControlTemplate TargetType="GridSplitter">
                                            <Border Background="{DynamicResource DividerBrush}" CornerRadius="2"/>
                                        </ControlTemplate>
                                    </GridSplitter.Template>
                                </GridSplitter>

                                <Grid Grid.Row="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,1" Padding="12,8">
                                        <DockPanel>
                                            <TextBlock Text="ESTRUCTURA" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource CaptionTextBrush}" VerticalAlignment="Center"/>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource IconButtonStyle}" Command="{Binding DataContext.CopyStructureCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Copiar estructura" Width="26" Height="26">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                            </Button>
                                        </DockPanel>
                                    </Border>

                                    <Expander Grid.Row="1" Header="Datos de cabecera" IsExpanded="False">
                                        <Grid Margin="12,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DataContext.CurrentTableHeaderInfo.RecordCount, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Registros: {0}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DataContext.CurrentTableHeaderInfo.FieldCount, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Campos: {0}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DataContext.CurrentTableHeaderInfo.HeaderSize, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Cabecera: {0} bytes}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DataContext.CurrentTableHeaderInfo.RecordSize, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Registro: {0} bytes}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding DataContext.CurrentTableHeaderInfo.FileTypeDescription, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Tipo: {0}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding DataContext.CurrentTableHeaderInfo.FullPath, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Ruta: {0}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Expander>

                                    <Border Grid.Row="2" Padding="12,6,12,4" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
                                        <TextBlock Text="{Binding DataContext.CurrentTableDisplayName, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    </Border>

                                    <Border Grid.Row="3" Padding="12,8" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Style="{StaticResource IconButtonStyle}" Command="{Binding DataContext.SaveCodePageToTableCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Guardar codepage" Width="28" Height="28">
                                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                                <Button Style="{StaticResource IconButtonStyle}" Command="{Binding DataContext.ApplyCodePageCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Reabrir con codepage" Width="28" Height="28">
                                                    <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                            </StackPanel>
                                            <ComboBox ItemsSource="{Binding DataContext.AvailableCodePages, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding DataContext.SelectedCodePageOption, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" DisplayMemberPath="Label" Width="145"/>
                                        </DockPanel>
                                    </Border>

                                    <DataGrid Grid.Row="4" ItemsSource="{Binding DataContext.CurrentTableStructure, RelativeSource={RelativeSource AncestorType=Window}}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single" BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Campo" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="60"/>
                                            <DataGridTextColumn Header="Len" Binding="{Binding Length}" Width="40"/>
                                            <DataGridTextColumn Header="Dec" Binding="{Binding DecimalCount}" Width="40"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Grid>
                        </Border>
                    </ControlTemplate>

                    <DataTemplate DataType="{x:Type vm:TableTabViewModel}">
                        <Control Template="{StaticResource FileExplorerTemplate}"/>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type vm:SqlConsoleViewModel}">
                        <Border Background="{DynamicResource LayerBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="{DynamicResource SubLayerBackgroundBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0" Padding="12,10">
                                    <TextBlock Text="ESQUEMA DE TABLAS" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource CaptionTextBrush}"/>
                                </Border>
                                <TreeView ItemsSource="{Binding SchemaItems}" BorderThickness="0" Background="Transparent" Margin="4">
                                    <TreeView.Resources>
                                        <!-- Estilo para que el CheckBox armonice con el tema -->
                                        <Style TargetType="CheckBox">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="0,0,8,0"/>
                                            <Style.Resources>
                                                <!-- Forzar colores del CheckBox si es necesario, o confiar en el estilo global -->
                                            </Style.Resources>
                                        </Style>
                                    </TreeView.Resources>
                                    <TreeView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Insertar seleccionados (separados por comas)" 
                                                      Command="{Binding InsertItemCommand}" 
                                                      CommandParameter="{Binding Path=PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </TreeView.ContextMenu>
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                            <Setter Property="Padding" Value="4,2"/>
                                            <Setter Property="IsExpanded" Value="False"/>
                                            <!-- Sobrescribir colores de selección nativos de WPF para que usen nuestro tema -->
                                            <Style.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{Binding Source={StaticResource ListItemSelectedBackgroundBrush}, Path=Color}"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{Binding Source={StaticResource ListItemSelectedTextBrush}, Path=Color}"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{Binding Source={StaticResource ListItemSelectedBackgroundBrush}, Path=Color}" Opacity="0.4"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{Binding Source={StaticResource ListItemSelectedTextBrush}, Path=Color}"/>
                                            </Style.Resources>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <StackPanel Orientation="Horizontal" Margin="0,2" Background="Transparent"
                                                        infra:EventBindingHelper.MouseDoubleClickCommand="{Binding DataContext.InsertItemCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                        infra:EventBindingHelper.MouseDoubleClickCommandParameter="{Binding}">
                                                <CheckBox IsChecked="{Binding IsChecked}"/>
                                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <TextBlock Text="{Binding Details}" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center" 
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ContentControl.Resources>

                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                                <Setter Property="Template" Value="{StaticResource FileExplorerTemplate}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>

            <!-- Splitter derecho -->
            <GridSplitter Grid.Column="3"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Cursor="SizeWE"
                          Margin="0"/>

            <!-- ─────────────────────────────────────────────────── -->
            <!--  PANEL DERECHO: Pestañas de tablas                   -->
            <!-- ─────────────────────────────────────────────────── -->
            <Border Grid.Column="4"
                    Background="{DynamicResource LayerBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="6"
                                      Color="{DynamicResource ShadowColor}"
                                      Opacity="1" Direction="270"/>
                </Border.Effect>

                <!-- Estado vacío (sin tabs abiertos) -->
                <Grid>
                    <Border x:Name="EmptyStatePlaceholder"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="32">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="48"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource CaptionTextBrush}"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="Abrí un archivo DBF para comenzar"
                                       FontSize="14"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Seleccioná una conexión, elegí un archivo y hacé doble clic o presioná Abrir DBF."
                                       FontSize="12"
                                       Foreground="{DynamicResource CaptionTextBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="300"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OpenTables.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <infra:CachedTabControl ItemsSource="{Binding OpenTables}"
                                            SelectedItem="{Binding SelectedOpenTable, Mode=TwoWay}">
                        <infra:CachedTabControl.Resources>
                            <DataTemplate DataType="{x:Type vm:TableTabViewModel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Filtro SQL -->
                                        <RowDefinition Height="Auto"/> <!-- Indicador activo -->
                                        <RowDefinition Height="*"/>    <!-- DataGrid -->
                                        <RowDefinition Height="Auto"/> <!-- Footer -->
                                    </Grid.RowDefinitions>

                                    <!-- Barra de filtro SQL -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource SubLayerBackgroundBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,4">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Left"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    ToolTip="Filtro rápido"
                                                    Margin="0,0,4,0"
                                                    Width="28" Height="28">
                                                <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </Button>

                                            <Button DockPanel.Dock="Right"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    Command="{Binding ClearFilterCommand}"
                                                    ToolTip="Quitar filtro"
                                                    Width="28" Height="28"
                                                    Margin="4,0,0,0">
                                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                           Foreground="{DynamicResource DangerBrush}"/>
                                            </Button>

                                            <Button DockPanel.Dock="Right"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Command="{Binding ApplySqlFilterCommand}"
                                                    ToolTip="Aplicar filtro (Enter)"
                                                    Width="32" Height="28" Padding="0"
                                                    Margin="4,0,0,0">
                                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </Button>

                                            <TextBox Text="{Binding SqlFilter, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas"
                                                     FontSize="13"
                                                     VerticalContentAlignment="Center"
                                                     Padding="6,2">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding ApplySqlFilterCommand}"/>
                                                    <KeyBinding Key="Escape" Command="{Binding ClearFilterCommand}"/>
                                                </TextBox.InputBindings>
                                            </TextBox>
                                        </DockPanel>
                                    </Border>

                                    <!-- Indicador de filtro activo -->
                                    <Border Grid.Row="1"
                                            Padding="12,5"
                                            Background="{DynamicResource AccentSubtleBrush}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="0,0,0,1"
                                            Visibility="{Binding IsFilterActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding CurrentFilterText}" FontSize="12"
                                                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- DataGrid -->
                                    <DataGrid Grid.Row="2"
                                              x:Name="TableDataGrid"
                                              ItemsSource="{Binding CurrentTableView}"
                                              SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
                                              SelectionChanged="TableDataGrid_OnSelectionChanged"
                                              AutoGeneratingColumn="OnAutoGeneratingColumn"
                                              PreviewMouseRightButtonDown="TableDataGrid_OnPreviewMouseRightButtonDown"
                                              AutoGenerateColumns="True"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserSortColumns="True"
                                              CanUserResizeRows="False"
                                              SelectionUnit="FullRow"
                                              SelectionMode="Extended"
                                              BorderThickness="0"
                                              VirtualizingStackPanel.IsVirtualizing="True"
                                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                                              EnableRowVirtualization="True"
                                              EnableColumnVirtualization="True">
                                        <DataGrid.InputBindings>
                                            <KeyBinding Key="Delete" 
                                                        Command="{Binding DataContext.DeleteSelectedRecordCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataGrid.InputBindings>
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Filtrar por valor" Icon="{infra:Icon Text=&#xE71C;}">
                                                    <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='='}" 
                                                              Command="{Binding FilterByValueCommand}" CommandParameter="{Binding LastRightClickedCellInfo}"/>
                                                    <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='&lt;&gt;'}"
                                                              Command="{Binding FilterByValueCommand}" CommandParameter="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterParamOperatorConverter}, ConverterParameter='&lt;&gt;'}"/>
                                                    <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='&gt;'}"
                                                              Command="{Binding FilterByValueCommand}" CommandParameter="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterParamOperatorConverter}, ConverterParameter='&gt;'}"/>
                                                    <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='&lt;'}"
                                                              Command="{Binding FilterByValueCommand}" CommandParameter="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterParamOperatorConverter}, ConverterParameter='&lt;'}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Personalizado..." Icon="{infra:Icon Text=&#xE70F;}">
                                                        <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='=:CUSTOM'}"
                                                                  Command="{Binding FilterCustomCommand}" CommandParameter="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterParamOperatorConverter}, ConverterParameter='='}"/>
                                                        <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='&lt;&gt;:CUSTOM'}"
                                                                  Command="{Binding FilterCustomCommand}" CommandParameter="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterParamOperatorConverter}, ConverterParameter='&lt;&gt;'}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='&gt;:CUSTOM'}"
                                                                  Command="{Binding FilterCustomCommand}" CommandParameter="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterParamOperatorConverter}, ConverterParameter='&gt;'}"/>
                                                        <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='&gt;=:CUSTOM'}"
                                                                  Command="{Binding FilterCustomCommand}" CommandParameter="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterParamOperatorConverter}, ConverterParameter='&gt;='}"/>
                                                        <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='&lt;:CUSTOM'}"
                                                                  Command="{Binding FilterCustomCommand}" CommandParameter="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterParamOperatorConverter}, ConverterParameter='&lt;'}"/>
                                                        <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='&lt;=:CUSTOM'}"
                                                                  Command="{Binding FilterCustomCommand}" CommandParameter="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterParamOperatorConverter}, ConverterParameter='&lt;='}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='ENTRE:CUSTOM'}"
                                                                  Command="{Binding FilterBetweenCommand}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterDisplayConverter}, ConverterParameter='CONTIENE:CUSTOM'}"
                                                                  Command="{Binding FilterCustomCommand}" CommandParameter="{Binding LastRightClickedCellInfo, Converter={StaticResource FilterParamOperatorConverter}, ConverterParameter='CONTIENE'}"/>
                                                    </MenuItem>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Quitar todos los filtros" Command="{Binding ClearFilterCommand}" Icon="{infra:Icon Text=&#xE894;}"/>
                                                <Separator/>
                                                <MenuItem Header="Seleccionar todo" Command="SelectAll" Icon="{infra:Icon Text=&#xE8B1;}"/>
                                                <MenuItem Header="Invertir selección" 
                                                          Command="{Binding InvertSelectionCommand}" 
                                                          CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget}"
                                                          Icon="{infra:Icon Text=&#xE8B1;}"/>
                                                <Separator/>
                                                <MenuItem Header="Cambiar valor..." 
                                                          Icon="{infra:Icon Text=&#xE70F;}"
                                                          Command="{Binding ChangeValueCommand}"/>
                                                <Separator/>
                                                <MenuItem Header="Copiar" Command="Copy" Icon="{infra:Icon Text=&#xE8C8;}"/>
                                                <MenuItem Header="Exportar..." Command="{Binding ExportCommand}" Icon="{infra:Icon Text=&#xE78C;}"/>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                    </DataGrid>

                                    <!-- Pie de página (Contadores) -->
                                    <Border Grid.Row="3"
                                            Background="{DynamicResource SubLayerBackgroundBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="0,1,0,0"
                                            Padding="12,4">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                                           Foreground="{DynamicResource CaptionTextBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Registros: " Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                                <TextBlock Text="{Binding FilteredRecords}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12"/>
                                                <TextBlock Text=" de " Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                                <TextBlock Text="{Binding TotalRecords}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                            </StackPanel>

                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                                                        Visibility="{Binding IsFilterActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Border Background="{DynamicResource AccentSubtleBrush}" CornerRadius="4" Padding="8,2">
                                                    <TextBlock Text="Filtro Activo" FontSize="11" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>

                            <!-- Template para Consola SQL -->
                            <DataTemplate DataType="{x:Type vm:SqlConsoleViewModel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="200" MinHeight="100"/> <!-- Editor SQL -->
                                        <RowDefinition Height="5"/>                  <!-- Splitter -->
                                        <RowDefinition Height="*"/>                  <!-- Resultados -->
                                        <RowDefinition Height="Auto"/>               <!-- Barra de estado -->
                                    </Grid.RowDefinitions>

                                    <!-- Editor SQL -->
                                    <Border Grid.Row="0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBox Text="{Binding SqlQuery, UpdateSourceTrigger=PropertyChanged}"
                                                     infra:TextBoxHelper.BindSelection="True"
                                                     infra:TextBoxHelper.SelectedText="{Binding SelectedText, Mode=TwoWay}"
                                                     infra:TextBoxHelper.CaretIndex="{Binding CaretIndex, Mode=TwoWay}"
                                                     infra:TextBoxHelper.FocusTrigger="{Binding TriggerFocus, Mode=TwoWay}"
                                                     AcceptsReturn="True"
                                                     AcceptsTab="True"
                                                     FontFamily="Consolas"
                                                     FontSize="14"
                                                     BorderThickness="0"
                                                     Padding="10"
                                                     Background="{DynamicResource AppBackgroundBrush}"
                                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="F5" Command="{Binding ExecuteCommand}"/>
                                                    <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding ExecuteCommand}"/>
                                                </TextBox.InputBindings>
                                            </TextBox>
                                            
                                            <!-- Botón Ejecutar flotante -->
                                            <Button Command="{Binding ExecuteCommand}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    Margin="0,0,20,10"
                                                    Padding="15,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Ejecutar (F5)" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Splitter -->
                                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

                                    <!-- Resultados -->
                                    <Border Grid.Row="2" Background="{DynamicResource AppBackgroundBrush}">
                                        <Grid>
                                            <!-- DataGrid de resultados -->
                                            <DataGrid ItemsSource="{Binding Results}"
                                                      IsReadOnly="True"
                                                      AutoGenerateColumns="True"
                                                      AutoGeneratingColumn="OnAutoGeneratingColumn"
                                                      BorderThickness="0"
                                                      VirtualizingStackPanel.IsVirtualizing="True"
                                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                      Visibility="{Binding Results, Converter={StaticResource NullToVisibilityConverter}}"/>

                                            <!-- Estado ocupado -->
                                            <Border Background="{DynamicResource OverlayBrush}" 
                                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                                                    <TextBlock Text="Ejecutando consulta..." Margin="0,10,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Sin resultados / Placeholder -->
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        Visibility="{Binding Results, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
                                                <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="48" 
                                                           Foreground="{DynamicResource CaptionTextBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Los resultados aparecerán aquí" Margin="0,10,0,0" 
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Barra de estado local -->
                                    <Border Grid.Row="3" Background="{DynamicResource SubLayerBackgroundBrush}" Padding="10,5" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0">
                                        <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </infra:CachedTabControl.Resources>

                        <infra:CachedTabControl.Style>
                            <Style TargetType="{x:Type infra:CachedTabControl}" BasedOn="{StaticResource {x:Type infra:CachedTabControl}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OpenTables.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </infra:CachedTabControl.Style>

                        <!-- Header de cada pestaña -->
                        <infra:CachedTabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Header}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"
                                               MaxWidth="200"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Style="{StaticResource TabCloseButtonStyle}"
                                            Command="{Binding CloseCommand}"
                                            ToolTip="Cerrar esta pestaña">
                                        <TextBlock Text="&#xE711;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="9"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </infra:CachedTabControl.ItemTemplate>
                    </infra:CachedTabControl>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  STATUS BAR                                                      -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource StatusBarBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <DockPanel>
                <!-- Estado dirty (derecha) -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="DirtyIndicator"
                             Width="7" Height="7"
                             Margin="0,0,5,0"
                             VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTableTab.HasPendingChanges}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource WarnBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding DirtyStatus}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>

                <!-- Mensaje de estado (izquierda) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE946;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="{DynamicResource CaptionTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
